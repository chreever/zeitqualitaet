<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — Zeitqualität</title>
  
  <meta property="og:type" content="article">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  
  {# Dynamisches Vorschaubild für Social Media #}
  {% set ogImage = post_image | default(image) %}
  {% if ogImage %}
    <meta property="og:image" content="https://zeitqualitaet.at{{ ogImage | url }}">
  {% else %}
    <meta property="og:image" content="https://zeitqualitaet.at/img/christian-portraet.jpg">
  {% endif %}

  {# Video-Daten für Facebook und Messenger #}
  {% set ogVideo = featured_video | default(video) %}
  {% if ogVideo %}
    <meta property="og:video" content="https://zeitqualitaet.at{{ ogVideo | url }}">
    <meta property="og:video:secure_url" content="https://zeitqualitaet.at{{ ogVideo | url }}">
    <meta property="og:video:type" content="video/mp4">
  {% endif %}

  <link rel="icon" type="image/svg+xml" href="/img/zq-favicon.svg?v=2">
  <link rel="alternate icon" href="/img/zq-favicon.png?v=2">
  <link rel="apple-touch-icon" href="/img/zq-favicon.png?v=2">

  <style>
    /* Absolute Pfade mit / am Anfang für die Schriften */
    @font-face { font-family: 'Cormorant Garamond'; src: url('/fonts/cormorant-garamond.woff2') format('woff2'); font-weight: 400; font-display: swap; }
    @font-face { font-family: 'Cormorant Garamond'; src: url('/fonts/cormorant-garamond-500.woff2') format('woff2'); font-weight: 500; font-display: swap; }
    @font-face { font-family: 'Figtree'; src: url('/fonts/figtree.woff2') format('woff2'); font-weight: 300; font-display: swap; }
    @font-face { font-family: 'Figtree'; src: url('/fonts/figtree-400.woff2') format('woff2'); font-weight: 400; font-display: swap; }
    @font-face { font-family: 'IBM Plex Mono'; src: url('/fonts/ibm-plex-mono.woff2') format('woff2'); font-weight: 400; font-display: swap; }

    :root {
      --bg: #08090e; --bg-warm: #0c0d14; --bg-card: #11121a; --bg-elevated: #1a1b26;
      --text: #e2dfd8; --text-muted: #918d84; --text-dim: #5c5950; 
      --accent: #d4a56a; --accent-light: #e8c48e; --accent-dim: rgba(212, 165, 106, 0.1);
      --border: #222330; --border-light: #1a1b26;
      --font-display: 'Cormorant Garamond', Georgia, serif; 
      --font-body: 'Figtree', system-ui, sans-serif;
      --font-mono: 'IBM Plex Mono', monospace;
      --radius: 10px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--font-body); background: var(--bg); color: var(--text); line-height: 1.85; font-weight: 300; -webkit-font-smoothing: antialiased; }
    
    .starfield { position: fixed; inset: 0; z-index: -1; pointer-events: none; }
    .starfield canvas { width: 100%; height: 100%; }

    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(8, 9, 14, 0.85); backdrop-filter: blur(28px); border-bottom: 1px solid var(--border-light); }
    .nav-inner { max-width: 1100px; margin: 0 auto; padding: 0 2rem; height: 80px; display: flex; align-items: center; justify-content: space-between; }
    .logo-container { display: flex; align-items: center; gap: 12px; text-decoration: none; }

    .article-container { max-width: 760px; margin: 120px auto 5rem; padding: 0 2rem; }
    #media-container { width: 100%; margin-bottom: 3rem; }
    .article-image { width: 100%; height: 400px; object-fit: cover; border-radius: var(--radius); border: 1px solid var(--border-light); }
    
    .back-btn { display: inline-block; margin-bottom: 2rem; font-family: var(--font-mono); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); border: 1px solid var(--border-light); padding: 8px 18px; border-radius: 100px; text-decoration: none; transition: 0.3s; }
    .back-btn:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }

    .post-content h1 { font-family: var(--font-display); font-size: clamp(2.2rem, 5vw, 3rem); margin-bottom: 1.5rem; color: var(--accent); font-weight: 400; line-height: 1.2; text-transform: uppercase; letter-spacing: -0.02em; }
    .post-content h2 { font-family: var(--font-display); font-size: 1.85rem; margin: 3rem 0 1rem; color: var(--accent-light); font-weight: 400; }
    .post-content p { margin-bottom: 1.5rem; font-size: 1.1rem; color: var(--text-muted); }
    .post-content blockquote { border-left: 2px solid var(--accent); padding: 1.5rem; margin: 2.5rem 0; font-family: var(--font-display); font-size: 1.3rem; font-style: italic; color: var(--text-dim); background: linear-gradient(90deg, var(--accent-dim) 0%, transparent 100%); }
    .post-content ol { list-style: none; counter-reset: post-counter; margin: 2rem 0; padding: 0; }
    .post-content ol li { counter-increment: post-counter; position: relative; padding-left: 3.2rem; margin-bottom: 1.5rem; font-size: 1.1rem; color: var(--text-muted); line-height: 1.8; }
    .post-content ol li::before { content: counter(post-counter); position: absolute; left: 0; top: 0.1rem; width: 28px; height: 28px; border-radius: 50%; background: var(--accent-dim); border: 1px solid rgba(212, 165, 106, 0.3); color: var(--accent); display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 0.8rem; font-weight: 600; }
    .post-content ul { list-style: none; margin: 1.5rem 0; padding: 0; }
    .post-content ul li { position: relative; padding-left: 1.5rem; margin-bottom: 0.8rem; color: var(--text-muted); }
    .post-content ul li::before { content: '◦'; position: absolute; left: 0; color: var(--accent); font-size: 1.2rem; }

    /* ── NEU: BILDER & CAPTIONS IM TEXT ── */
    .post-content img {
      max-width: 100%;
      height: auto;
      border-radius: var(--radius);
      margin: 2rem auto;
      display: block;
      cursor: zoom-in;
      border: 1px solid var(--border-light);
      transition: transform 0.3s ease;
    }
    
    .post-content img:hover {
      transform: scale(1.01);
      border-color: var(--accent-dim);
    }
    
    .post-content figure {
      margin: 2.5rem 0;
      text-align: center;
    }
    
    .post-content figcaption {
      margin-top: 0.8rem;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--accent);
      opacity: 0.7;
      line-height: 1.5;
      max-width: 80%;
      margin-left: auto;
      margin-right: auto;
    }
    
    .post-content img + em {
      display: block;
      text-align: center;
      margin-top: -1.5rem;
      margin-bottom: 2rem;
      font-size: 0.8rem;
      font-family: var(--font-mono);
      color: var(--text-dim);
    }

    /* ── AUTO-DISCLAIMER FÜR ASTRO-EXPERIMENT ── */
    .astro-disclaimer { 
      margin-top: 3.5rem; 
      padding: 1.5rem 2rem; 
      background: var(--bg-elevated); 
      border-left: 3px solid var(--accent); 
      border-radius: var(--radius); 
      font-size: 0.9rem; 
      color: var(--text-muted); 
      line-height: 1.6; 
      font-style: italic; 
      box-shadow: 0 4px 20px rgba(0,0,0,0.2); 
    }
    .astro-disclaimer strong { 
      color: var(--accent); 
      font-style: normal; 
      letter-spacing: 0.05em; 
      text-transform: uppercase; 
      font-size: 0.8rem;
    }

    .share-btn { display: inline-flex; align-items: center; gap: 0.6rem; background: transparent; color: var(--accent); border: 1px solid var(--accent); padding: 0.7rem 1.5rem; border-radius: 100px; font-family: var(--font-body); font-size: 0.9rem; cursor: pointer; transition: 0.3s; margin-top: 2rem; }
    .share-btn:hover { background: var(--accent-dim); transform: translateY(-2px); }

    footer { border-top: 1px solid var(--border-light); padding: 3rem 2rem; text-align: center; color: var(--text-dim); margin-top: 4rem; font-size: 0.85rem; }

    @media (max-width: 768px) {
      .nav-inner { height: 70px; padding: 0 1.5rem; }
      .article-container { margin-top: 100px; }
      .article-image { height: 260px; }
      .post-content figcaption { max-width: 95%; }
    }
  </style>
</head>
<body>

<div class="starfield"><canvas id="stars"></canvas></div>

<nav>
  <div class="nav-inner">
    <a href="/" class="logo-container">
      <svg viewBox="0 0 120 120" style="height: 40px; width: 40px;">
        <defs><linearGradient id="g" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#f2d5a3"/><stop offset="100%" stop-color="#a67b45"/></linearGradient></defs>
        <circle cx="60" cy="60" r="54" fill="none" stroke="url(#g)" stroke-width="1" opacity="0.3"/>
        <path d="M60 22 Q60 60 22 60 Q60 60 60 98 Q60 60 98 60 Q60 60 60 22 Z" fill="url(#g)"/>
      </svg>
      <span style="font-family: var(--font-display); font-size: 1.5rem; color: var(--text); letter-spacing: 0.05em;">Zeitqualität</span>
    </a>
    <a href="/" style="font-size: 0.7rem; color: var(--text-muted); font-family: var(--font-mono); text-transform: uppercase; text-decoration: none;">← Home</a>
  </div>
</nav>

<div class="article-container">
  <a href="javascript:history.back()" class="back-btn">← Zurück</a>
  
  <div id="media-container">
    {% set finalImage = post_image or image %}
    {% set finalVideo = featured_video or video %}

    {% if finalImage %}
      <img class="article-image" src="{{ finalImage | url }}" alt="{{ title }}">
    {% elif finalVideo %}
      <video class="article-image" autoplay muted loop playsinline>
        <source src="{{ finalVideo | url }}#t=0.1" type="video/mp4">
      </video>
    {% endif %}
  </div>
  
  <article id="post-content" class="post-content">
    <h1>{{ title }}</h1>
    {{ content | safe }}

    {# --- AUTOMATISCHER DISCLAIMER FÜR EXPERIMENTE --- #}
    {% if category == "Astro-Experiment" %}
      <div class="astro-disclaimer">
        <strong>⚠️ Wichtiger Hinweis</strong><br>
        Die "Astro-Investment-Tagebücher" sind ein rein redaktionelles Gedankenspiel zur Finanzastrologie und dokumentieren einen privaten Selbstversuch. Dieser Beitrag stellt ausdrücklich <strong>keine Anlageberatung</strong>, Finanzanalyse oder Aufforderung zum Kauf/Verkauf von Wertpapieren dar. Jedes Investment an der Börse birgt Risiken bis hin zum Totalverlust.
      </div>
    {% endif %}
  </article>
  
  <button id="share-btn" class="share-btn">↗ Beitrag teilen</button>
</div>

<footer>
  <p>© 2026 Zeitqualität · Christian Balas</p>
</footer>

<div id="image-modal" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(8,9,14,0.95); backdrop-filter:blur(10px); cursor:zoom-out; align-items:center; justify-content:center; padding:2rem; flex-direction:column;">
  <img id="modal-img" src="" style="max-width:95%; max-height:85vh; border-radius:var(--radius); box-shadow:0 0 50px rgba(0,0,0,0.5); border:1px solid var(--border);">
  <div id="modal-caption" style="color:var(--accent); font-family:var(--font-mono); margin-top:1.5rem; font-size:0.9rem; text-align:center; max-width:800px;"></div>
  <div style="position:absolute; top:2rem; right:2rem; color:var(--text-muted); font-family:var(--font-mono); font-size:0.8rem;">ESC ZUM SCHLIESSEN</div>
</div>

<script>
  // Hintergrund Sterne
  (function(){const c=document.getElementById('stars'),x=c.getContext('2d');let s=[];function r(){c.width=window.innerWidth;c.height=window.innerHeight}function f(){s=[];for(let i=0;i<120;i++)s.push({x:Math.random()*c.width,y:Math.random()*c.height,z:Math.random()*1.5,p:Math.random()*Math.PI*2})}function d(t){x.clearRect(0,0,c.width,c.height);s.forEach(a=>{x.beginPath();x.arc(a.x,a.y,a.z,0,Math.PI*2);x.fillStyle="#e2dfd8";x.globalAlpha=Math.sin(t*0.001+a.p)*0.4+0.5;x.fill()});requestAnimationFrame(d)}r();f();d(0);window.addEventListener('resize',()=>{r();f()})})();

  // Share Button
  const sb = document.getElementById('share-btn');
  if(sb) sb.addEventListener('click', async () => {
    if(navigator.share) { try { await navigator.share({title:document.title, url:window.location.href}); } catch(e){} }
    else { navigator.clipboard.writeText(window.location.href); sb.innerHTML = '✨ Link kopiert!'; setTimeout(()=>sb.innerHTML='↗ Beitrag teilen',2000); }
  });

  // ── NEU: LIGHTBOX LOGIK ──
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('image-modal');
    const modalImg = document.getElementById('modal-img');
    const modalCaption = document.getElementById('modal-caption');
    const content = document.getElementById('post-content');

    if(content) {
      content.querySelectorAll('img').forEach(img => {
        img.onclick = () => {
          modal.style.display = 'flex';
          modalImg.src = img.src;
          
          // Versuche eine Bildunterschrift zu finden (Figcaption oder kursiver Text darunter)
          const parent = img.closest('figure');
          const caption = parent ? parent.querySelector('figcaption') : img.nextElementSibling;
          
          if (caption && (caption.tagName === 'FIGCAPTION' || caption.tagName === 'EM')) {
            modalCaption.innerText = caption.innerText;
          } else {
            modalCaption.innerText = "";
          }
        };
      });
    }

    // Schließen beim Klick aufs Modal oder Drücken von ESC
    modal.onclick = () => { modal.style.display = 'none'; };
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') modal.style.display = 'none';
    });
  });
</script>
</body>
</html>
